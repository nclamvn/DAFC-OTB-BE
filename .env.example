# ============================================================================
# DAFC OTB Backend — Environment Variables
# Copy to .env and update values for your environment
# ============================================================================

# Database — SQL Server (schema=dbo: chỉ thao tác trên dbo schema)
DATABASE_URL="sqlserver://localhost:1433;database=dafc_otb;user=sa;password=YourPassword;encrypt=true;trustServerCertificate=true;schema=dbo"

# JWT
JWT_SECRET="change-this-to-a-random-64-char-string-in-production"

# Server
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# File Storage (Phase 4+)
# S3_BUCKET=dafc-otb-files
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
