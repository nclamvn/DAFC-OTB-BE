  category         Category?    @relation("CategoryToSalesHistoryAgg", fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sub_category     SubCategory? @relation("SubCategoryToSalesHistoryAgg", fields: [sub_category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  season_type      SeasonType?  @relation("SeasonTypeToSalesHistoryAgg", fields: [season_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  season           Season       @relation("SeasonToSalesHistoryAgg", fields: [season_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

