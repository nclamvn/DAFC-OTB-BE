// ============================================
// ORDER CONFIRMATION
// ============================================

model OrderConfirmation {
  id                      BigInt    @id @default(autoincrement())
  ticket_id               BigInt
  image_url               String?
  sku                     String    @db.NVarChar(50)
  name                    String?   @db.NVarChar(300)
  collection_name         String?   @db.NVarChar(200)
  color                   String?   @db.NVarChar(100)
  division                String?   @db.NVarChar(100)
  product_type            String?   @db.NVarChar(200)
  department              String?   @db.NVarChar(200)
  carry_forward           String?   @db.NVarChar(200)
  composition             String?   @db.NVarChar(500)
  theme                   String?   @db.NVarChar(200)
  style_name              String?   @db.NVarChar(300)
  total_units             Int?      @default(0)
  size                    String?   @db.NVarChar(20)
  brand_id                String?   @db.NVarChar(50)
  color_code              String?   @db.NVarChar(50)
  fsr                     String?   @db.NVarChar(50)
  wholesale_sgd           Decimal?  @db.Decimal(18, 2)
  rrp_sgd                 Decimal?  @db.Decimal(18, 2)
  regional_rrp            Decimal?  @db.Decimal(18, 2)
  total_price_sgd         Decimal?  @db.Decimal(18, 2)
  mod                     String?   @db.NVarChar(50)
  ves                     String?   @db.NVarChar(50)
  in_catalogue            String?   @db.NVarChar(50)
  gruppo                  String?   @db.NVarChar(100)
  tipology                String?   @db.NVarChar(100)
  sku_type                String?   @db.NVarChar(100)
  gca                     String?   @db.NVarChar(50)
  window                  String?   @db.NVarChar(100)
  heel                    String?   @db.NVarChar(50)
  dimension               String?   @db.NVarChar(100)
  finish                  String?   @db.NVarChar(100)
  delivery                String?   @db.NVarChar(100)
  currency                String?   @db.NVarChar(10)
  price_mod_single        Decimal?  @db.Decimal(18, 2)
  price_mod_single_retail Decimal?  @db.Decimal(18, 2)
  amount                  Decimal?  @db.Decimal(18, 2)
  amount_retail           Decimal?  @db.Decimal(18, 2)
  product_status          String?   @db.NVarChar(50)
  size2                   String?   @db.NVarChar(20)
  status                  String    @default("DRAFT") @db.NVarChar(30)
  created_by              BigInt?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
  updated_by              BigInt?

  // Relations
  ticket  Ticket @relation("TicketToOrderConfirmation", fields: [ticket_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator User?  @relation("CreatedOrderConfirmations", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  receipt_confirmations ReceiptConfirmation[] @relation("OrderToReceipt")

  @@index([ticket_id])
  @@index([status])
  @@index([sku])
  @@map("order_confirmation")
}

// ============================================
// RECEIPT CONFIRMATION
// ============================================

model ReceiptConfirmation {
  id                      BigInt    @id @default(autoincrement())
  order_confirmation_id   BigInt
  ticket_id               BigInt

  // Receipt verification fields
  received_units          Int?      @default(0)
  actual_unit_price       Decimal?  @db.Decimal(18, 2)
  actual_total_price      Decimal?  @db.Decimal(18, 2)
  receipt_currency        String?   @db.NVarChar(10)
  receipt_comment         String?   @db.NVarChar(1000)

  // Status & audit
  status                  String    @default("DRAFT") @db.NVarChar(30)
  created_by              BigInt?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
  updated_by              BigInt?

  // Relations
  order_confirmation OrderConfirmation @relation("OrderToReceipt", fields: [order_confirmation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ticket             Ticket            @relation("TicketToReceipt", fields: [ticket_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator            User?             @relation("CreatedReceiptConfirmations", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([order_confirmation_id])
  @@index([ticket_id])
  @@index([status])
  @@map("receipt_confirmation")
}

// ============================================
// APPROVAL WORKFLOW & TICKETS
// ============================================

model ApprovalStatus {
  id         BigInt   @id @default(autoincrement())
  name       String
  is_active  Boolean  @default(true)
  created_by BigInt?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  updated_by BigInt?

  @@map("approval_statuses")
}

model Ticket {
  id              BigInt   @id @default(autoincrement())
  budget_id       BigInt
  season_group_id BigInt
  season_id       BigInt
  status          String   @default("PENDING")
  created_by      BigInt
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  updated_by      BigInt?

  // Relations
  budget                    Budget              @relation("BudgetToTicket", fields: [budget_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  season_group              SeasonGroup         @relation("SeasonGroupToTicket", fields: [season_group_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  season                    Season              @relation("SeasonToTicket", fields: [season_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator                   User                @relation("CreatedTickets", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ticket_approval_logs      TicketApprovalLog[]  @relation("TicketToApprovalLog")
  snapshot_allocate_headers AllocateHeader[]     @relation("TicketToSnapshotHeaders")
  order_confirmations       OrderConfirmation[]  @relation("TicketToOrderConfirmation")
  receipt_confirmations     ReceiptConfirmation[] @relation("TicketToReceipt")

  @@map("ticket")
}

model ApprovalWorkflow {
  id             BigInt   @id @default(autoincrement())
  group_brand_id BigInt
  workflow_name  String
  created_by     BigInt?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  updated_by     BigInt?

  // Relations
  group_brand              GroupBrand              @relation("GroupBrandToWorkflow", fields: [group_brand_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  approval_workflow_levels ApprovalWorkflowLevel[] @relation("WorkflowToLevel")

  @@map("approval_workflow")
}

model ApprovalWorkflowLevel {
  id                   BigInt   @id @default(autoincrement())
  approval_workflow_id BigInt
  level_order          Int
  level_name           String
  approver_user_id     BigInt
  is_required          Boolean
  created_by           BigInt?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  updated_by           BigInt?

  // Relations
  approval_workflow    ApprovalWorkflow    @relation("WorkflowToLevel", fields: [approval_workflow_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  approver_user        User                @relation("ApproverUser", fields: [approver_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ticket_approval_logs TicketApprovalLog[] @relation("LevelToApprovalLog")

  @@map("approval_workflow_level")
}

model TicketApprovalLog {
  id                         BigInt    @id @default(autoincrement())
  ticket_id                  BigInt
  approval_workflow_level_id BigInt
  approver_user_id           BigInt
  is_approved                Boolean
  comment                    String?
  approved_at                DateTime?
  created_by                 BigInt?
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt
  updated_by                 BigInt?

  // Relations
  ticket                  Ticket                @relation("TicketToApprovalLog", fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  approval_workflow_level ApprovalWorkflowLevel @relation("LevelToApprovalLog", fields: [approval_workflow_level_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approver_user           User                  @relation("ApproverLogs", fields: [approver_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("approval_request_log")
}
